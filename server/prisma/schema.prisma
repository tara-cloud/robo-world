// Prisma schema for Electro device management server
// Run: node migrate.js

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id               String    @id @default(cuid())
  projectId        String    @unique @default(cuid())
  name             String    @unique
  description      String    @default("")
  mqttHost         String    @default("")
  mqttPort         Int       @default(1883)
  otaTopic         String    @default("ota")
  configTopic      String    @default("taraConfig")
  createdAt        DateTime  @default(now())
  devices          Device[]
  services         Service[]
}

model Service {
  id          String   @id @default(cuid())
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String
  name        String
  description String   @default("")
  url         String   @default("")
  status      String   @default("unknown") // online | offline | unknown
  createdAt   DateTime @default(now())
}

model Device {
  id              String    @id @default(cuid())
  deviceId        String    @unique
  deviceName      String
  deviceType      String
  firmwareVersion String
  ipAddress       String?
  lastSeen        DateTime  @default(now())
  createdAt       DateTime  @default(now())

  project   Project?  @relation(fields: [projectId], references: [id])
  projectId String?

  configs     DeviceConfig[]
  readings    SensorReading[]
  components  DeviceComponent[]
  pipeline    PipelineRule[]
}

model DeviceConfig {
  id        String   @id @default(cuid())
  device    Device   @relation(fields: [deviceId], references: [deviceId])
  deviceId  String
  version   String
  config    Json
  createdAt DateTime @default(now())

  @@unique([deviceId, version])
}

model SensorReading {
  id          String   @id @default(cuid())
  device      Device   @relation(fields: [deviceId], references: [deviceId])
  deviceId    String
  temperature Float?
  humidity    Float?
  light       Int?
  extra       Json?
  recordedAt  DateTime @default(now())
}

model DeviceComponent {
  id        String      @id @default(cuid())
  device    Device      @relation(fields: [deviceId], references: [deviceId])
  deviceId  String
  name      String
  type      String
  protocol  String?
  address   String?
  pins      DevicePin[]

  @@unique([deviceId, name])
}

model DevicePin {
  id          String          @id @default(cuid())
  component   DeviceComponent @relation(fields: [componentId], references: [id], onDelete: Cascade)
  componentId String
  deviceId    String
  pin         String
  label       String
  direction   String

  @@unique([deviceId, pin])
}

model PipelineRule {
  id        String   @id @default(cuid())
  device    Device   @relation(fields: [deviceId], references: [deviceId])
  deviceId  String
  pinLabel  String
  action    String
  config    Json
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
}

model DeviceLog {
  id         String   @id @default(cuid())
  projectId  String
  deviceName String
  timestamp  DateTime @default(now())
  level      String
  logger     String
  message    String
  createdAt  DateTime @default(now())

  @@index([projectId, createdAt])
}

model Face {
  id        String   @id @default(cuid())
  name      String   @unique
  label     String
  cmds      Json
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

// Key/value store for server-side settings (e.g. logTtlDays)
model ServerSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}
