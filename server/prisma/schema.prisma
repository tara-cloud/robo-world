// Prisma schema for Electro device management server
// Run: node migrate.js

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Device {
  id              String    @id @default(cuid())
  deviceId        String    @unique
  deviceName      String
  deviceType      String
  firmwareVersion String
  lastSeen        DateTime  @default(now())
  createdAt       DateTime  @default(now())

  configs   DeviceConfig[]
  readings  SensorReading[]
  pins      DevicePin[]
  pipeline  PipelineRule[]
}

model DeviceConfig {
  id        String   @id @default(cuid())
  device    Device   @relation(fields: [deviceId], references: [deviceId])
  deviceId  String
  version   String
  config    Json
  createdAt DateTime @default(now())

  @@unique([deviceId, version])
}

model SensorReading {
  id          String   @id @default(cuid())
  device      Device   @relation(fields: [deviceId], references: [deviceId])
  deviceId    String
  temperature Float?
  humidity    Float?
  light       Int?
  extra       Json?
  recordedAt  DateTime @default(now())
}

model DevicePin {
  id        String  @id @default(cuid())
  device    Device  @relation(fields: [deviceId], references: [deviceId])
  deviceId  String
  pin       String  // GPIO number or label like "3V3", "GND"
  label     String  // e.g. "SDA", "SOIL_MOISTURE", "PUMP"
  direction String  // "input" | "output" | "power" | "i2c"
  component String  // e.g. "SH1106 OLED", "DHT11"
  protocol  String? // "I2C" | "DIGITAL" | "ANALOG" | "PWM"
  notes     String?

  @@unique([deviceId, pin])
}

model PipelineRule {
  id        String   @id @default(cuid())
  device    Device   @relation(fields: [deviceId], references: [deviceId])
  deviceId  String
  pinLabel  String   // matches DevicePin.label
  action    String   // "log" | "threshold" | "mqtt_publish" | "actuator"
  config    Json     // action-specific config
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
}
